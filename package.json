{
    "name": "@typpi/codex-skills",
    "version": "0.1.0",
    "private": false,
    "description": "Personal multi-skill repository for reusable Codex workflows.",
    "keywords": [
        "agent-skill",
        "agent-skills",
        "ai-agent",
        "codex",
        "openai",
        "universal"
    ],
    "homepage": "https://github.com/Nick2bad4u/codex-skills#readme",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/codex-skills/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/codex-skills.git"
    },
    "license": "Unlicense",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://github.com/Nick2bad4u)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "type": "module",
    "types": "./types.d.ts",
    "files": [
        "skills/",
        "schemas/",
        "tools/",
        "AGENTS.md",
        "CHANGELOG.md",
        "CODE_OF_CONDUCT.md",
        "CONTRIBUTING.md",
        "README.md",
        "SECURITY.md",
        "SUPPORT.md",
        "LICENSE",
        "LICENSE.txt",
        "cliff.toml",
        "tsconfig.json",
        "tsdoc.json",
        "types.d.ts"
    ],
    "scripts": {
        "changelog:generate": "git-cliff --config cliff.toml --output CHANGELOG.md",
        "changelog:preview": "git-cliff --config cliff.toml --unreleased",
        "changelog:release-notes": "git-cliff --config cliff.toml --current --strip all",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "icons:generate": "node tools/generate-skill-icons.mjs",
        "install:local": "npx skills add . -g --agent universal --copy -y",
        "lint": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:actions": "actionlint",
        "lint:all": "npm run lint && npm run lint:package-json && npm run lint:remark && npm run lint:secretlint && npm run lint:stylelint && npm run lint:tsdoc && npm run lint:yamllint",
        "lint:external": "npm run lint:actions && npm run lint:gitleaks",
        "lint:gitleaks": "gitleaks dir --config .gitleaks.toml .",
        "lint:package-json": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:remark": "remark . --frail --ignore-path .remarkignore",
        "lint:remark:fix": "remark . --ignore-path .remarkignore --output",
        "lint:secretlint": "secretlint .",
        "lint:stylelint": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
        "lint:tsdoc": "node tools/validate-tsdoc-config.mjs",
        "lint:yamllint": "yamllint -c .yamllint .",
        "pack:dry-run": "npm pack --dry-run",
        "publish:local": "npm run release:verify && npm publish --access public",
        "release:verify": "npm run validate && npm run typecheck && npm run lint:all && npm run format:check && npm run pack:dry-run",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "update-actions": "npx actions-up --yes --style sha",
        "update-deps": "npx ncu -i --install never && npm update --force && npm install --force",
        "validate": "node tools/validate-skills.mjs"
    },
    "overrides": {
        "esbuild": "0.28.1"
    },
    "devDependencies": {
        "@microsoft/tsdoc-config": "^0.18.1",
        "eslint": "^10.5.0",
        "eslint-config-nick2bad4u": "^2.0.4",
        "git-cliff": "^2.13.1",
        "gitleaks-config-nick2bad4u": "^1.0.2",
        "npm-package-json-lint": "^10.4.1",
        "npm-package-json-lint-config-nick2bad4u": "^1.0.3",
        "prettier": "^3.8.4",
        "prettier-config-nick2bad4u": "^1.0.17",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.0.10",
        "remark-lint-frontmatter-schema": "^3.15.4",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.1.0",
        "stylelint": "^17.13.0",
        "stylelint-config-nick2bad4u": "^1.0.19",
        "tsdoc-config-nick2bad4u": "^1.0.5",
        "yamllint-config-nick2bad4u": "^1.0.2"
    },
    "engines": {
        "node": ">=22.16.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
